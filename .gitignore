# This file is used to ignore files which are generated during the build process
# Ignoring the files here prevents them from being committed by accident
# as well as avoids conflicts when working with multiple branches

# Visual Studio cache directory
.vs/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt
sysinfo.txt.meta

# Builds
*.apk
*.aab
*.unitypackage
*.exe

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Ignore these folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
.utmp/

# Ignore Visual Studio misc files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# VR-specific (SteamVR)
Modern\ Room_BurstDebugInformation_DoNotShip/
UpgradeLog.htm