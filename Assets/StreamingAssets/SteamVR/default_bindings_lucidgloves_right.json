{
  "name": "LucidGloves — Dental VR (Right Hand)",
  "controller_type": "lucidgloves",
  "category": "steamvr_input",
  "bindings": {
    "/actions/dental": {
      "sources": [
        {
          "path": "/user/hand/right/input/skeleton/right",
          "mode": "skeleton",
          "inputs": {
            "skeleton": {
              "output": "/actions/dental/in/SkeletonRight"
            }
          }
        },
        {
          "path": "/user/hand/right/input/grip",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/dental/in/GrabRight"
            }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "button",
          "inputs": {
            "click": {
              "output": "/actions/dental/in/PinchRight"
            }
          }
        },
        {
          "path": "/user/hand/right/pose/raw",
          "mode": "pose",
          "inputs": {
            "pose": {
              "output": "/actions/dental/in/PoseRight"
            }
          }
        }
      ],
      "haptics": [
        {
          "path": "/user/hand/right/output/haptic",
          "output": "/actions/dental/out/HapticRight"
        }
      ]
    }
  },
  "description": "Default bindings for the right LucidGlove in the Dental VR simulation."
}
